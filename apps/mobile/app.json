{
  "expo": {
    "name": "Camp DaddyMan",
    "slug": "camp-daddyman",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.campdaddyman.app"
    },
    "android": {
      "package": "com.campdaddyman.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "updates": {
      "url": "https://u.expo.dev/635cd17a-b97d-44cd-9432-eddfae9c2af8",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 3000
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-video",
      "expo-updates"
    ],
    "extra": {
      "eas": {
        "projectId": "635cd17a-b97d-44cd-9432-eddfae9c2af8"
      }
    },
    "owner": "campdaddyman"
  }
}
