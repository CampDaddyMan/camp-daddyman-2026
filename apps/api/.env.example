# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# URL of the deployed frontend (used for CORS + Stripe redirect URLs)
FRONTEND_URL=https://campdaddyman.com

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Railway: copy from the Railway Postgres service's "Connect" tab
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/camp_daddyman

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for BullMQ transcoding job queue (optional — degrades gracefully if missing)
# Railway: copy from the Railway Redis service's "Connect" tab
# Upstash: copy the REDIS_URL from your Upstash console
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret for signing JWTs — use a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=change_me_to_a_long_random_secret

# ── Cloudflare R2 (media storage) ────────────────────────────────────────────
# Account ID from Cloudflare dashboard → R2
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# R2 API credentials — create from R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# R2 bucket name (create in Cloudflare R2 dashboard)
R2_BUCKET_NAME=camp-daddyman-media

# Public URL for the R2 bucket (enable public access in R2 bucket settings)
# Format: https://pub-XXXXXXXX.r2.dev  OR a custom domain
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev

# ── Stripe ────────────────────────────────────────────────────────────────────
# Secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Webhook secret from https://dashboard.stripe.com/webhooks
# After creating the webhook, copy the "Signing secret"
# Endpoint URL to register: https://your-api-domain.com/api/subscriptions/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create Products + Prices in the Stripe dashboard
# Products → Add product → set recurring price → copy the "Price ID"
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_...

# From address — must be a verified domain in Resend
EMAIL_FROM=noreply@campdaddyman.com
