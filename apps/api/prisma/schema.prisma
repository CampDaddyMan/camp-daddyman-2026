generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users ─────────────────────────────────────────────────────────────────────

model User {
  id          String  @id @default(cuid())
  email       String  @unique
  username    String  @unique
  password    String
  displayName String?
  avatar      String?
  bio         String?
  isAdmin        Boolean @default(false)
  isCreator      Boolean @default(false)
  isTester       Boolean @default(false)
  isBanned       Boolean @default(false)
  emailVerified  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  content      Content[]
  subscription Subscription?
  likes        Like[]
  comments     Comment[]
  watchHistory WatchHistory[]
  followers              Follow[]       @relation("UserFollowing")
  following              Follow[]       @relation("UserFollowers")
  notifications          Notification[] @relation("NotificationRecipient")
  triggeredNotifications Notification[] @relation("NotificationActor")
  tokens                 Token[]
  sessions               Session[]
  reports                Report[]       @relation("ReportedBy")
  polls                  Poll[]
  pollVotes              PollVote[]
  pollOptionsAsArtist    PollOption[] @relation("PollOptionArtist")
  orders                 Order[]
}

model Token {
  id        String    @id @default(cuid())
  userId    String
  type      TokenType
  token     String    @unique
  metadata  String?   // JSON: device context or hashed OTP
  expiresAt DateTime
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId, type])
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  TWO_FACTOR_LOGIN
  TWO_FACTOR_REGISTER
  FORCE_SESSION
}

// ── Sessions ──────────────────────────────────────────────────────────────────

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jwtId        String   @unique
  deviceId     String
  deviceLabel  String
  ipAddress    String
  userAgent    String?
  expiresAt    DateTime
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([jwtId])
}

// ── Content ───────────────────────────────────────────────────────────────────

model Content {
  id          String        @id @default(cuid())
  title       String
  description String?
  type        ContentType
  status      ContentStatus @default(PROCESSING)
  privacy     Privacy       @default(PUBLIC)

  mediaUrl     String?
  hlsUrl       String?
  thumbnailUrl String?
  duration     Int? // seconds

  tags String[]

  views Int @default(0)

  cardWidth  Int?    @default(224)
  cardAspect String? @default("video")
  
  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  likes         Like[]
  comments      Comment[]
  watchHistory  WatchHistory[]
  notifications Notification[]
  reports       Report[]
  pollOptions   PollOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creatorId])
  @@index([type, status, privacy])
  
}

enum ContentType {
  FILM
  MUSIC
  PODCAST
  SPOKEN_WORD
  DADDYMAN_ISMS
  BOOK
}

enum ContentStatus {
  PROCESSING
  ACTIVE
  ARCHIVED
  DELETED
}

enum Privacy {
  PUBLIC
  PRIVATE
  SUBSCRIBERS_ONLY
}

// ── Subscriptions ─────────────────────────────────────────────────────────────

model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan   SubscriptionPlan
  status SubscriptionStatus @default(ACTIVE)

  stripeCustomerId     String?
  stripeSubscriptionId String?

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SubscriptionPlan {
  FREE
  PRO
  PREMIUM
  CREATOR
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

// ── Engagement ────────────────────────────────────────────────────────────────

model Like {
  id        String  @id @default(cuid())
  userId    String
  contentId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, contentId])
}

model Comment {
  id        String  @id @default(cuid())
  text      String
  userId    String
  contentId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([contentId])
}

model Follow {
  id          String @id @default(cuid())
  followerId  String
  followingId String
  follower    User   @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User   @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model WatchHistory {
  id        String  @id @default(cuid())
  userId    String
  contentId String
  progress  Int     @default(0) // seconds watched
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  watchedAt DateTime @default(now())

  @@unique([userId, contentId])
  @@index([userId])
}

// ── Notifications ─────────────────────────────────────────────────────────────

model Notification {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  read    Boolean          @default(false)

  actorId   String?
  contentId String?

  user    User     @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor   User?    @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  content Content? @relation(fields: [contentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

enum NotificationType {
  NEW_CONTENT   // followed creator posted new content
  NEW_LIKE      // someone liked your content
  NEW_COMMENT   // someone commented on your content
  NEW_FOLLOWER  // someone followed you
}

// ── Reports ───────────────────────────────────────────────────────────────────

model Report {
  id        String       @id @default(cuid())
  contentId String
  reporterId String
  reason    ReportReason
  detail    String?
  status    ReportStatus @default(PENDING)

  content  Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  reporter User    @relation("ReportedBy", fields: [reporterId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@unique([contentId, reporterId])
  @@index([status, createdAt])
}

enum ReportReason {
  SPAM
  INAPPROPRIATE
  COPYRIGHT
  HATE_SPEECH
  MISINFORMATION
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

// ── Polls ─────────────────────────────────────────────────────────────────────

model Poll {
  id          String     @id @default(cuid())
  title       String
  description String?
  imageUrl    String?
  pollType    PollType   @default(CONTENT_VOTE)
  status      PollStatus @default(ACTIVE)
  creatorId   String
  creator     User       @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  options     PollOption[]
  votes       PollVote[]
  endsAt      DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([creatorId, status])
}

model PollOption {
  id        String   @id @default(cuid())
  pollId    String
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  label     String
  order     Int      @default(0)

  // CONTENT_VOTE
  contentId String?
  content   Content? @relation(fields: [contentId], references: [id])

  // ARTIST_VOTE
  artistId  String?
  artist    User?    @relation("PollOptionArtist", fields: [artistId], references: [id])

  // CUSTOM
  imageUrl  String?
  body      String?

  votes     PollVote[]
}

model PollVote {
  id        String     @id @default(cuid())
  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id])
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([pollId, userId])
}

enum PollStatus {
  ACTIVE
  CLOSED
}

enum PollType {
  CONTENT_VOTE
  ARTIST_VOTE
  CUSTOM
}

// ── Partners & Advertising ────────────────────────────────────────────────────

model Partner {
  id          String        @id @default(cuid())
  name        String
  email       String        @unique
  website     String?
  logo        String?
  description String?
  type        PartnerType   @default(ADVERTISER)
  status      PartnerStatus @default(PENDING)
  contactName String?
  phone       String?
  featured    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  ads         Ad[]
}

model AdPlacement {
  id          String   @id @default(cuid())
  name        String
  location    String
  description String?
  pricePerDay Float    @default(0)
  width       Int?
  height      Int?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  ads         Ad[]
}

model Ad {
  id          String    @id @default(cuid())
  partnerId   String
  partner     Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  placementId String
  placement   AdPlacement @relation(fields: [placementId], references: [id], onDelete: Cascade)
  title       String
  body        String?
  imageUrl    String?
  linkUrl     String
  startsAt    DateTime
  endsAt      DateTime
  status      AdStatus  @default(PENDING)
  impressions Int       @default(0)
  clicks      Int       @default(0)
  paidAmount  Float     @default(0)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([placementId, status, startsAt, endsAt])
}

enum PartnerType {
  ADVERTISER
  SPONSOR
  DONOR
  COLLABORATOR
}

enum PartnerStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum AdStatus {
  PENDING
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

// ── Shop ──────────────────────────────────────────────────────────────────────

model Product {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  description  String?
  type         ProductType
  price        Float
  comparePrice Float?
  imageUrl     String?
  images       String[]
  status       ProductStatus @default(DRAFT)
  featured     Boolean       @default(false)
  tags         String[]
  fileUrl               String?
  optionGroups          Json?
  memberDiscountEnabled Boolean @default(false)

  variants   ProductVariant[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, type])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  sku       String?
  price     Float?
  inventory Int     @default(0)
  options   Json

  orderItems OrderItem[]

  @@index([productId])
}

model Order {
  id      String      @id @default(cuid())
  userId  String?
  user    User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  email   String
  status  OrderStatus @default(PENDING)

  subtotal Float
  discount Float @default(0)
  total    Float

  stripeSessionId String?
  stripePaymentId String?

  shippingName    String?
  shippingLine1   String?
  shippingLine2   String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?
  shippingCountry String?
  trackingNumber  String?
  shippedAt       DateTime?

  notes String?

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status, createdAt])
  @@index([stripeSessionId])
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product        @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  name        String
  variantName String?
  price       Float
  quantity    Int

  downloadUrl    String?
  downloadExpiry DateTime?

  @@index([orderId])
}

enum ProductType {
  PHYSICAL
  DIGITAL
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}
