generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users ─────────────────────────────────────────────────────────────────────

model User {
  id          String  @id @default(cuid())
  email       String  @unique
  username    String  @unique
  password    String
  displayName String?
  avatar      String?
  bio         String?
  isAdmin        Boolean @default(false)
  isCreator      Boolean @default(false)
  isTester       Boolean @default(false)
  isBanned       Boolean @default(false)
  emailVerified  Boolean @default(false)
  loginAttempts  Int       @default(0)
  lockedUntil    DateTime?

  emailNewFollower Boolean @default(true)
  emailNewContent  Boolean @default(true)
  emailNewComment  Boolean @default(true)
  emailNewTip      Boolean @default(true)

  pushNewFollower Boolean @default(true)
  pushNewContent  Boolean @default(true)
  pushNewComment  Boolean @default(true)
  pushNewTip      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  content      Content[]
  subscription Subscription?
  profiles     Profile[]
  likes        Like[]
  comments     Comment[]
  watchHistory WatchHistory[]
  savedContent SavedContent[]
  followers              Follow[]       @relation("UserFollowing")
  following              Follow[]       @relation("UserFollowers")
  notifications          Notification[] @relation("NotificationRecipient")
  triggeredNotifications Notification[] @relation("NotificationActor")
  tokens                 Token[]
  sessions               Session[]
  reports                Report[]       @relation("ReportedBy")
  polls                  Poll[]
  pollVotes              PollVote[]
  pollOptionsAsArtist    PollOption[] @relation("PollOptionArtist")
  orders                 Order[]
  albums                 Album[]
  tipsSent               Tip[]          @relation("TipSender")
  tipsReceived           Tip[]          @relation("TipRecipient")
  commentLikes           CommentLike[]
  playlists              Playlist[]
  productReviews         ProductReview[]
  series                 Series[]
  seriesComments         SeriesComment[]
  pushSubscriptions      PushSubscription[]
  expoPushTokens         ExpoPushToken[]
  liveStreams            LiveStream[]
  contentCredits         ContentCredit[]
  referredById           String?
  referredBy             User?    @relation("Referrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals              User[]   @relation("Referrals")
  posts                  Post[]
  wishlistItems          ProductWishlist[]
  backInStockReqs        BackInStockRequest[]
  xp                     Int              @default(0)
  xpEvents               UserXpEvent[]
  badges                 UserBadge[]
  currentStreak          Int              @default(0)
  longestStreak          Int              @default(0)
  lastStreakDate         DateTime?        @db.Date
  loyaltyRedemptions     LoyaltyRedemption[]
  // Conferred stations — set by Elder/admin, never by XP alone
  // Values: ARK_BUILDER | GARDENER | FAADA | null
  // GARDENER and FAADA have no badge and no public announcement (by constitution)
  station                String?
  livityActs             Livity[]        @relation("LivitySubmitter")
  verifiedLivityActs     Livity[]        @relation("LivityVerifier")
  journey                UserJourney?
  journeyEntries         JourneyEntry[]
}

model Token {
  id        String    @id @default(cuid())
  userId    String
  type      TokenType
  token     String    @unique
  metadata  String?   // JSON: device context or hashed OTP
  expiresAt DateTime
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId, type])
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  TWO_FACTOR_LOGIN
  TWO_FACTOR_REGISTER
  FORCE_SESSION
  WEB_HANDOFF
}

// ── Sessions ──────────────────────────────────────────────────────────────────

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jwtId        String   @unique
  deviceId     String
  deviceLabel  String
  ipAddress    String
  userAgent    String?
  expiresAt    DateTime
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([jwtId])
}

// ── Content ───────────────────────────────────────────────────────────────────

model Content {
  id          String        @id @default(cuid())
  title       String
  description String?
  type        ContentType
  status      ContentStatus @default(PROCESSING)
  privacy     Privacy       @default(PUBLIC)

  mediaUrl     String?
  hlsUrl       String?
  thumbnailUrl String?
  duration     Int? // seconds

  tags String[]

  views     Int       @default(0)
  publishAt DateTime?

  cardWidth  Int?    @default(224)
  cardAspect String? @default("video")

  featured  Boolean @default(false)
  rating    String? // "G" | "PG" | "PG-13" | "R" | "EXPLICIT" — null means NR
  lyrics      String?
  canvasUrl   String? // short looping background video for audio content
  introStart  Int?    // seconds — when "Skip Intro" button appears
  introEnd    Int?    // seconds — where playhead jumps to on skip
  previewUrl      String? // short muted clip shown on hover in content rows
  chapters        Json?   // Array of {time: number, label: string}
  xpWatchSeconds  Int     @default(30) // seconds watched before XP is awarded

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  likes         Like[]
  comments      Comment[]
  watchHistory  WatchHistory[]
  savedBy       SavedContent[]
  viewLogs      ViewLog[]
  notifications Notification[]
  reports       Report[]
  pollOptions   PollOption[]
  albumTracks    AlbumTrack[]
  playlistItems  PlaylistItem[]
  credits        ContentCredit[]
  profileHistory ProfileWatchHistory[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creatorId])
  @@index([type, status, privacy])
}

enum ContentType {
  FILM
  MUSIC
  PODCAST
  SPOKEN_WORD
  DADDYMAN_ISMS
  BOOK
}

enum ContentStatus {
  PROCESSING
  ACTIVE
  SCHEDULED
  ARCHIVED
  DELETED
}

enum Privacy {
  PUBLIC
  PRIVATE
  SUBSCRIBERS_ONLY
}

// ── Subscriptions ─────────────────────────────────────────────────────────────

model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan   SubscriptionPlan
  status SubscriptionStatus @default(ACTIVE)

  stripeCustomerId     String?
  stripeSubscriptionId String?

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SubscriptionPlan {
  FREE
  PRO
  PREMIUM
  CREATOR
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

// ── Tips ─────────────────────────────────────────────────────────────────────

model Tip {
  id              String   @id @default(cuid())
  amountCents     Int
  message         String?
  stripeSessionId String   @unique
  senderId        String
  sender          User     @relation("TipSender",    fields: [senderId],    references: [id], onDelete: Cascade)
  recipientId     String
  recipient       User     @relation("TipRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@index([recipientId])
  @@index([senderId])
}

// ── Engagement ────────────────────────────────────────────────────────────────

model Like {
  id        String  @id @default(cuid())
  userId    String
  contentId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, contentId])
}

model ViewLog {
  id        String   @id @default(cuid())
  contentId String
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([contentId, createdAt])
}

model SavedContent {
  id        String  @id @default(cuid())
  userId    String
  contentId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, contentId])
}

model Comment {
  id        String  @id @default(cuid())
  text      String
  userId    String
  contentId String
  parentId  String?
  isPinned  Boolean @default(false)

  user      User     @relation(fields: [userId],    references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  likes     CommentLike[]

  createdAt DateTime @default(now())

  @@index([contentId])
  @@index([parentId])
}

model CommentLike {
  id        String  @id @default(cuid())
  userId    String
  commentId String
  user      User    @relation(fields: [userId],    references: [id], onDelete: Cascade)
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, commentId])
}

model Follow {
  id          String @id @default(cuid())
  followerId  String
  followingId String
  follower    User   @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User   @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model WatchHistory {
  id        String  @id @default(cuid())
  userId    String
  contentId String
  progress  Int     @default(0) // seconds watched
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  watchedAt DateTime @default(now())

  @@unique([userId, contentId])
  @@index([userId])
}

// ── Profiles ─────────────────────────────────────────────────────────────────

model Profile {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  avatar    String?  // hex color, e.g. "#e8b800"
  isKids    Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  watchHistory ProfileWatchHistory[]

  @@index([userId])
}

model ProfileWatchHistory {
  id        String   @id @default(cuid())
  profileId String
  contentId String
  progress  Int      @default(0)
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  watchedAt DateTime @default(now())

  @@unique([profileId, contentId])
  @@index([profileId])
}

// ── Notifications ─────────────────────────────────────────────────────────────

model Notification {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  read    Boolean          @default(false)

  actorId       String?
  contentId     String?
  milestone     Int?
  milestoneKind String?  // 'FOLLOWERS' | 'VIEWS'

  user    User     @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor   User?    @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  content Content? @relation(fields: [contentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

enum NotificationType {
  NEW_CONTENT   // followed creator posted new content
  NEW_LIKE      // someone liked your content
  NEW_COMMENT   // someone commented on your content
  NEW_FOLLOWER  // someone followed you
  NEW_TIP       // someone tipped you
  MILESTONE     // creator hit a follower or view count milestone
}

// ── Reports ───────────────────────────────────────────────────────────────────

model Report {
  id        String       @id @default(cuid())
  contentId String
  reporterId String
  reason    ReportReason
  detail    String?
  status    ReportStatus @default(PENDING)

  content  Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  reporter User    @relation("ReportedBy", fields: [reporterId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@unique([contentId, reporterId])
  @@index([status, createdAt])
}

enum ReportReason {
  SPAM
  INAPPROPRIATE
  COPYRIGHT
  HATE_SPEECH
  MISINFORMATION
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

// ── Polls ─────────────────────────────────────────────────────────────────────

model Poll {
  id            String     @id @default(cuid())
  title         String
  description   String?
  imageUrl      String?
  pollType      PollType   @default(CONTENT_VOTE)
  status        PollStatus @default(ACTIVE)
  creatorId     String
  creator       User       @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  options       PollOption[]
  votes         PollVote[]
  startsAt      DateTime?
  endsAt        DateTime?
  allowMultiple Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([creatorId, status])
}

model PollOption {
  id        String   @id @default(cuid())
  pollId    String
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  label     String
  order     Int      @default(0)

  // CONTENT_VOTE
  contentId String?
  content   Content? @relation(fields: [contentId], references: [id])

  // ARTIST_VOTE
  artistId  String?
  artist    User?    @relation("PollOptionArtist", fields: [artistId], references: [id])

  // CUSTOM
  imageUrl  String?
  body      String?

  votes     PollVote[]
}

model PollVote {
  id        String     @id @default(cuid())
  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id])
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([pollId, userId, optionId])
}

enum PollStatus {
  ACTIVE
  CLOSED
}

enum PollType {
  CONTENT_VOTE
  ARTIST_VOTE
  CUSTOM
}

// ── Partners & Advertising ────────────────────────────────────────────────────

model Partner {
  id          String        @id @default(cuid())
  name        String
  email       String        @unique
  website     String?
  logo        String?
  description String?
  type        PartnerType   @default(ADVERTISER)
  status      PartnerStatus @default(PENDING)
  contactName String?
  phone       String?
  featured    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  ads         Ad[]
}

model AdPlacement {
  id          String   @id @default(cuid())
  name        String
  location    String
  description String?
  pricePerDay Float    @default(0)
  width       Int?
  height      Int?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  ads         Ad[]
}

model Ad {
  id          String    @id @default(cuid())
  partnerId   String
  partner     Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  placementId String
  placement   AdPlacement @relation(fields: [placementId], references: [id], onDelete: Cascade)
  title       String
  body        String?
  imageUrl    String?
  linkUrl     String
  startsAt    DateTime
  endsAt      DateTime
  status      AdStatus  @default(PENDING)
  impressions           Int       @default(0)
  clicks                Int       @default(0)
  paidAmount            Float     @default(0)
  notes                 String?
  stripeSessionId       String?   @unique
  stripePaymentIntentId String?
  refundId              String?
  advertiserEmail       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([placementId, status, startsAt, endsAt])
}

enum PartnerType {
  ADVERTISER
  SPONSOR
  DONOR
  COLLABORATOR
}

enum PartnerStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum AdStatus {
  PENDING          // submitted, awaiting payment
  PENDING_REVIEW   // paid, awaiting Drew's content approval
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

// ── Shop ──────────────────────────────────────────────────────────────────────

model Product {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  description  String?
  type         ProductType
  price        Float
  comparePrice Float?
  imageUrl     String?
  images       String[]
  status       ProductStatus @default(DRAFT)
  featured     Boolean       @default(false)
  releaseDate  DateTime?
  tags         String[]
  fileUrl               String?
  optionGroups          Json?
  memberDiscountEnabled Boolean @default(false)

  variants         ProductVariant[]
  orderItems       OrderItem[]
  reviews          ProductReview[]
  wishlistItems    ProductWishlist[]
  backInStockReqs  BackInStockRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, type])
}

model BackInStockRequest {
  id        String   @id @default(cuid())
  productId String
  userId    String?
  email     String
  notified  Boolean  @default(false)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([productId, email])
  @@index([productId, notified])
}

model ProductWishlist {
  id        String  @id @default(cuid())
  userId    String
  productId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  sku       String?
  price     Float?
  inventory Int     @default(0)
  options   Json

  orderItems OrderItem[]

  @@index([productId])
}

model Order {
  id      String      @id @default(cuid())
  userId  String?
  user    User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  email   String
  status  OrderStatus @default(PENDING)

  subtotal Float
  discount Float @default(0)
  total    Float

  stripeSessionId String?
  stripePaymentId String?

  couponId       String?
  coupon         Coupon?  @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponCode     String?
  couponDiscount Float    @default(0)

  shippingName    String?
  shippingLine1   String?
  shippingLine2   String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?
  shippingCountry String?
  trackingNumber  String?
  shippedAt       DateTime?

  notes String?

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status, createdAt])
  @@index([stripeSessionId])
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product        @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  name        String
  variantName String?
  price       Float
  quantity    Int

  downloadUrl    String?
  downloadExpiry DateTime?

  @@index([orderId])
}

enum ProductType {
  PHYSICAL
  DIGITAL
}

enum CouponType {
  PERCENTAGE
  FIXED
}

model Coupon {
  id             String     @id @default(cuid())
  code           String     @unique
  type           CouponType
  value          Float
  minOrderAmount Float?
  maxUses        Int?
  maxUsesPerUser Int        @default(1)
  usedCount      Int        @default(0)
  active         Boolean    @default(true)
  expiresAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  orders         Order[]
  uses           CouponUse[]
}

model CouponUse {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  createdAt DateTime @default(now())
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId, userId])
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

// ── Albums ────────────────────────────────────────────────────────────────────

model Album {
  id          String          @id @default(cuid())
  title       String
  description String?
  coverUrl    String?
  releaseDate DateTime?
  genre       String?
  releaseType AlbumReleaseType @default(ALBUM)
  privacy     Privacy          @default(PUBLIC)
  creatorId   String
  creator     User             @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  tracks      AlbumTrack[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([creatorId])
  @@index([privacy, releaseType, createdAt])
}

enum AlbumReleaseType {
  ALBUM
  EP
  SINGLE
  COMPILATION
}

model AlbumTrack {
  albumId     String
  album       Album   @relation(fields: [albumId], references: [id], onDelete: Cascade)
  contentId   String
  content     Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  trackNumber Int
  discNumber  Int     @default(1)

  @@id([albumId, contentId])
  @@unique([albumId, discNumber, trackNumber])
  @@index([contentId])
}

// ── Product Reviews ───────────────────────────────────────────────────────────

model ProductReview {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int     // 1–5
  title     String?
  body      String?
  createdAt DateTime @default(now())

  @@unique([productId, userId])
  @@index([productId])
}

// ── Playlists ─────────────────────────────────────────────────────────────────

model Playlist {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  coverUrl    String?
  isPublic    Boolean        @default(false)
  items       PlaylistItem[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId])
}

model PlaylistItem {
  id         String   @id @default(cuid())
  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  contentId  String
  content    Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  position   Int
  addedAt    DateTime @default(now())

  @@unique([playlistId, contentId])
  @@index([playlistId, position])
}

// ── Series / Seasons / Episodes ───────────────────────────────────────────────

model Series {
  id          String          @id @default(cuid())
  title       String
  description String?
  coverUrl    String?
  bannerUrl   String?
  trailerUrl  String?
  genre       String?
  tags        String[]
  status      String          @default("ACTIVE") // ACTIVE | ARCHIVED
  privacy     Privacy         @default(PUBLIC)
  creatorId   String
  creator     User            @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  seasons     Season[]
  comments    SeriesComment[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([creatorId])
  @@index([privacy, status])
}

model SeriesComment {
  id        String          @id @default(cuid())
  text      String
  userId    String
  seriesId  String
  parentId  String?

  user      User            @relation(fields: [userId],   references: [id], onDelete: Cascade)
  series    Series          @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  parent    SeriesComment?  @relation("SeriesCommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   SeriesComment[] @relation("SeriesCommentReplies")

  createdAt DateTime @default(now())

  @@index([seriesId])
  @@index([parentId])
}

model Season {
  id          String    @id @default(cuid())
  seriesId    String
  series      Series    @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  number      Int
  title       String?
  description String?
  coverUrl    String?
  episodes    Episode[]
  createdAt   DateTime  @default(now())

  @@unique([seriesId, number])
  @@index([seriesId])
}

model Episode {
  id            String   @id @default(cuid())
  seasonId      String
  season        Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  episodeNumber Int
  title         String
  description   String?
  thumbnailUrl  String?
  mediaUrl      String?
  hlsUrl        String?
  duration      Int?
  views         Int      @default(0)
  rating        String?
  createdAt     DateTime @default(now())

  @@unique([seasonId, episodeNumber])
  @@index([seasonId])
}

// ── Push Subscriptions ────────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model ExpoPushToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String   // "ios" | "android"
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── Newsletter Subscribers ────────────────────────────────────────────────────

model EmailSubscriber {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  source           String    @default("website")
  unsubscribeToken String    @unique @default(cuid())
  unsubscribed     Boolean   @default(false)
  unsubscribedAt   DateTime?
  subscribedAt     DateTime  @default(now())

  @@index([unsubscribed])
}

// ── Content Credits ───────────────────────────────────────────────────────────

model ContentCredit {
  id        String  @id @default(cuid())
  contentId String
  userId    String
  role      String  // e.g. "Featured Artist", "Producer", "Director"

  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([contentId, userId])
  @@index([contentId])
  @@index([userId])
}

// ── Gamification ─────────────────────────────────────────────────────────────

model UserXpEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // 'LIKE' | 'COMMENT' | 'FOLLOW' | 'WATCH' | 'PURCHASE'
  refId     String   // contentId, orderId, creatorId — dedup key
  xp        Int
  createdAt DateTime @default(now())

  @@unique([userId, type, refId])
  @@index([userId])
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     String
  createdAt DateTime @default(now())

  @@unique([userId, badge])
  @@index([userId])
}

// ── Creator Posts ─────────────────────────────────────────────────────────────

model Post {
  id        String   @id @default(cuid())
  text      String
  imageUrl  String?
  creatorId String
  creator   User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([creatorId])
  @@index([createdAt(sort: Desc)])
}

// ── Live Streams ──────────────────────────────────────────────────────────────

model LiveStream {
  id            String    @id @default(cuid())
  title         String
  description   String?
  status        String    @default("idle") // idle | live | ended
  thumbnailUrl  String?
  cfStreamId    String    @unique
  cfStreamKey   String
  cfPlaybackUrl String
  cfWebRtcUrl   String?
  scheduledAt   DateTime?
  startedAt     DateTime?
  endedAt       DateTime?
  creatorId     String
  creator       User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@index([status])
  @@index([creatorId])
}

// ── Site Settings ─────────────────────────────────────────────────────────────

model SiteSetting {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @updatedAt
}

// ── Banner Slides ─────────────────────────────────────────────────────────────

model BannerSlide {
  id             String   @id @default(cuid())
  page           String   // "HOME" | "ARK"
  imageUrl       String
  linkUrl        String?
  caption        String?
  objectPosition String   @default("center")  // CSS object-position: top | center | bottom | left | right
  objectFit      String   @default("cover")   // CSS object-fit: cover | contain
  sortOrder      Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@index([page, sortOrder])
}

// ── Loyalty Shop ──────────────────────────────────────────────────────────────

model LoyaltyReward {
  id          String   @id @default(cuid())
  name        String
  description String?
  xpCost      Int
  type        String   // DISCOUNT | EARLY_ACCESS | EXCLUSIVE_CONTENT | CUSTOM
  value       String?  // coupon code, content id, or custom detail
  stock       Int?     // null = unlimited
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  redemptions LoyaltyRedemption[]
}

model LoyaltyRedemption {
  id        String        @id @default(cuid())
  userId    String
  rewardId  String
  xpSpent   Int
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward    LoyaltyReward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@unique([userId, rewardId])
  @@index([userId])
}

// ── Journey ───────────────────────────────────────────────────────────────────
// The Butterfly Journey Engine — one day at a time.
// JourneyDay is the curriculum. UserJourney tracks where a user is.
// JourneyEntry stores what the user wrote each day.

model JourneyDay {
  id              String   @id @default(cuid())
  dayNumber       Int      @unique
  phase           String   @default("EGG") // EGG | CATERPILLAR | J_SHAPE | CHRYSALIS | BUTTERFLY
  title           String
  lie             String   // The lie being dismantled
  truth           String   // The truth replacing it
  body            String   // The witnessing text (full body)
  daddyManism     String   // Drew's locked words
  reflectionPrompt String
  challengePrompt  String
  livityPrompt     String
  journalPrompt    String
  closingText      String
  published        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  entries          JourneyEntry[]

  @@index([dayNumber, published])
}

model UserJourney {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt   DateTime @default(now())
  currentDay  Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model JourneyEntry {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayNumber        Int
  journeyDay       JourneyDay  @relation(fields: [dayNumber], references: [dayNumber])
  reflectionText   String?
  challengeText    String?
  journalText      String?
  completedAt      DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([userId, dayNumber])
  @@index([userId])
}

// ── Livity ────────────────────────────────────────────────────────────────────
// Righteous living, witnessed and forever remembered.
// The real currency from J-Shape up — never self-reported.

model Livity {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation("LivitySubmitter", fields: [userId], references: [id], onDelete: Cascade)
  type         LivityType
  description  String
  status       LivityStatus @default(PENDING)
  witnessNote  String?
  verifiedById String?
  verifiedBy   User?        @relation("LivityVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)
  verifiedAt   DateTime?
  createdAt    DateTime     @default(now())

  @@index([userId, status])
  @@index([status, createdAt])
}

enum LivityType {
  GOOD           // Conscious Living — love, respect, community, mentoring
  CREATION       // Creation — song, poem, book, film, artwork
  PRESERVATION   // Preservation — culture, wisdom, stories, roots
  RECONCILIATION // Healing — restoring harmony, peacemaking
}

enum LivityStatus {
  PENDING
  APPROVED
  REJECTED
}
